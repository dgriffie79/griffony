entitytype :: enum {
    none
    player
    spawnpoint
    imp
    mancubus
}

entity :: struct {
    type: entitytype
    pos: vec3
    vel: vec3  
    orientation: quat
    frame: i32
    frametime: f32
    model: &voxelmodel
    height: f32
    radius: f32
    gravity : bool
}

entity.onground :: (e: &entity) -> bool {
    r := .85 * e.radius
    if terrain->getvoxelf32(e.pos.x, e.pos.y - f32.EPSILON, e.pos.z) != -1 {
        return true
    } elseif terrain->getvoxelf32(e.pos.x + r, e.pos.y - f32.EPSILON, e.pos.z) != -1 {
        return true
    } elseif terrain->getvoxelf32(e.pos.x - r, e.pos.y -  f32.EPSILON, e.pos.z) != -1 {
        return true
    } elseif terrain->getvoxelf32(e.pos.x, e.pos.y -  f32.EPSILON, e.pos.z + r) != -1 {
        return true
    } elseif terrain->getvoxelf32(e.pos.x, e.pos.y -  f32.EPSILON, e.pos.z - r) != -1 {
        return true
    }
    return false
}

entities : [..] entity

playmusic :: (music: music) {
    if audio_element->type() == .Undefined {
        doc := js.Global->get("document")
        audio_element = doc->call("createElement", "audio")
        audio_element->leak()
        logf(.Info, "Created audio element {}", audio_element->type())
    } 

    audio_element->set("src", musicfiles[music])
    audio_element->call("play")
}

stopmusic :: () {
    if audio_element->type() != .Undefined {
        audio_element->call("pause")
    }
}

reset :: () {
    player := &entities[playerindex]
    player.pos = vec3.{0, 0, 0}
    player.vel = vec3.{0, 0, 0}
    player.orientation = quat.{1.0, 0.0, 0.0, 0.0}
    player.gravity = true
    needsrespawn = true   
}

setupbuttons :: () {
    doc := js.Global->get("document")
    
    loadsettings()
    doc->call("getElementById", "forward")->set("value", settings.forward)
    doc->call("getElementById", "back")->set("value", settings.back)
    doc->call("getElementById", "left")->set("value", settings.left)
    doc->call("getElementById", "right")->set("value", settings.right)
    doc->call("getElementById", "up")->set("value", settings.up)
    doc->call("getElementById", "down")->set("value", settings.down)
    doc->call("getElementById", "jump")->set("value", settings.jump)
    doc->call("getElementById", "respawn")->set("value", settings.respawn)
    doc->call("getElementById", "playmode")->set("value", settings.playmode)
    doc->call("getElementById", "invert")->set("checked", settings.mouseinvert)

    menu := doc->call("getElementById", "main-menu")

    menu->call("addEventListener", "click", js.func((this, args) => {
        args[0]->call("stopPropagation")
        return js.Undefined
    }))

    menu->call("addEventListener", "keyup", js.func((this, args) => {
        args[0]->call("stopPropagation")
        return js.Undefined
    }))

    menu->call("addEventListener", "keydown", js.func((this, args) => {
        args[0]->call("stopPropagation")
        return js.Undefined
    }))

    menu->call("addEventListener", "change", js.func((this, args) => {
        target := args[0]->get("target")
        id := target->get("id")->as_str_temp()->or_return(js.Undefined)

        setkeybind :: macro (keybind: str) {
            value := target->get("value")->as_str()->or_return(js.Undefined)
            if keybind {
                keybind->free()
            }
            keybind = value
        }

        switch id {
            case "invert" {
                checked := target->get("checked")->as_bool()->or_return(js.Undefined)
                settings.mouseinvert = checked
            }
            case "forward" {
                setkeybind(settings.forward)
            }
            case "back" {
                setkeybind(settings.back)
            }
            case "left" {
                setkeybind(settings.left)
            }
            case "right" {
                setkeybind(settings.right)
            }
            case "up" {
                setkeybind(settings.up)
            }
            case "down" {
                setkeybind(settings.down)
            }
            case "jump" {
                setkeybind(settings.jump)
            }
            case "respawn" {
                setkeybind(settings.respawn)
            }
            case "playmode" {
                setkeybind(settings.playmode)
            }
        }

        savesettings()
        args[0]->call("stopPropagation")
        return js.Undefined
    }))

    if showingmenu {
        menu->set("style", "")
    }

    doc->call("addEventListener", "keydown", js.func((this, args) => {
        event := args[0]
        key := event->get("key")->as_str() ?? ""
        if key != "" {
            keystates->insert(key)  
        }
        return js.Undefined
    }))

    doc->call("addEventListener", "keyup", js.func((this, args) => {
        event := args[0]
        key := event->get("key")->as_str() ?? ""

        if key != "" {
            keystates->remove(key)
        }
        key->free()
        return js.Undefined
    }))

    doc->call("addEventListener", "mousemove", js.func((this, args) => {
        event := args[0]
        if pointerlocked {
            mousemovex = ~~ (event->get("movementX")->as_float() ?? 0.0)
            mousemovey = ~~ (event->get("movementY")->as_float() ?? 0.0)
        } else {
            mousex = ~~ (event->get("clientX")->as_float()?? 0.0)
            mousey = ~~ (event->get("clientY")->as_float()?? 0.0)
        }
        return js.Undefined
    }))

    doc->call("addEventListener", "pointerlockchange", js.func((this, args) => {
        if this->get("pointerLockElement")->type() == .Null {
            pointerlocked = false
        } else {
            pointerlocked = true
        }
        return js.Undefined
    }))

    doc->call("addEventListener", "click", js.func((this, args) => {
        if !pointerlocked {
            this->get("documentElement")->call("requestPointerLock")
        }
        if showingmenu {
            this->call("getElementById", "main-menu")->get("style")->set("display", "none")
            showingmenu = false
        } 
        return js.Undefined
    }))

    doc->call("addEventListener", "visibilitychange", js.func((this, args) => {
        lasttime = platform.__time() - lasttime
        return js.Undefined
    }))

    doc->call("addEventListener", "contextmenu", js.func((this, args) => {
        args[0]->call("preventDefault")
        return js.Undefined
    }))

    js.Global->get("window")->call("addEventListener", "resize", js.func((this, args) => {
        width := js.Global->get("innerWidth")->as_int() ?? cast(i32) viewport[0]
        height := js.Global->get("innerHeight")->as_int() ?? cast(i32) viewport[1]
        canvas := js.Global->get("document")->call("getElementById", "canvas")
        canvas->set("width", width)
        canvas->set("height", height)
        viewport = .[~~ width, ~~ height]
        glViewport(0, 0, width, height)
        return js.Undefined
    }))
}

shader :: struct {
    program: GLProgram
    vertex: GLShader
    fragment: GLShader
    viewportloc: GLUniformLocation
    voxelsloc: GLUniformLocation
    tilesloc: GLUniformLocation
    paletteloc: GLUniformLocation
    mvploc: GLUniformLocation
}

shader.createprogram :: (s: &shader, fragsrc: []u8, vertsrc: []u8) {
    s.vertex   = compile_shader(GL_VERTEX_SHADER, vertsrc)->expect("Failed to compile vertex shader")
    s.fragment = compile_shader(GL_FRAGMENT_SHADER, fragsrc)->expect("Failed to compile fragment shader")

    s.program = glCreateProgram()
    glAttachShader(s.program, s.vertex)
    glAttachShader(s.program, s.fragment)
    glLinkProgram(s.program)

    if glGetProgramParameter(s.program, GL_LINK_STATUS) == 0 {
        logf(.Error, "Failed to link program.")
        js.Global->get("console")->call("log", glGetProgramInfoLog(s.program))
    }

    s.viewportloc = glGetUniformLocation(s.program, "viewport")
    s.mvploc = glGetUniformLocation(s.program, "mvp")
    s.voxelsloc = glGetUniformLocation(s.program, "voxels")
    s.tilesloc = glGetUniformLocation(s.program, "tiles")
    s.paletteloc = glGetUniformLocation(s.program, "palette")
}

